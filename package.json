{
  "name": "@wazo/types",
  "version": "26.7.0",
  "description": "TS types for Wazo APIs",
  "types": "./dist/index.d.ts",
  "author": "Wazo (http://wazo.io)",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TinxHQ/wazo-ts-types.git"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts"
    },
    "./acl": {
      "types": "./dist/acl/index.d.ts",
      "default": "./dist/acl/index.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "npm run generate && npm run compile",
    "compile": "rm -rf ./dist && tsc --project tsconfig.json && tsc --project tsconfig.acl.json",
    "generate": "rm -rf ./src/schemas && node --experimental-strip-types ./src/build.ts && node --experimental-strip-types ./src/acl/generate.ts",
    "test": "jest"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.1",
    "dotenv": "^17.2.3",
    "jest": "^29.7.0",
    "swagger-typescript-api": "^13.1.3",
    "ts-jest": "^29.3.4",
    "typescript": "^5.8.3"
  }
}
